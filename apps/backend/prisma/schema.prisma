// apps/backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  name                String?
  phone               String?
  plan                String      @default("free") // free | pro | studio | label
  passwordHash        String?
  emailVerified       Boolean     @default(false)
  verificationToken   String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  artistName          String?
  metaAdAccountId     String?
  metaAccessToken     String?
  metaPixelId         String?
  metaBusinessId      String?
  spotifyArtistId     String?
  campaigns           Campaign[]
  adCreatives         AdCreative[]
  landingPages        LandingPage[]
  createdAt           DateTime    @default(now())
}

model LandingPage {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  artistSlug   String
  songSlug     String
  title        String
  description  String?
  thumbnailUrl String
  spotifyUrl   String?
  pixelId      String?
  createdAt    DateTime @default(now())

  @@unique([artistSlug, songSlug])
}

model Campaign {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  name           String
  metaCampaignId   String?
  metaAdSetId      String?
  metaAdId         String?
  metaAdSetIds     String[]       @default([])
  metaAdIds        String[]       @default([])
  status           CampaignStatus @default(DRAFT)
  budget           Float
  startDate        DateTime?
  endDate          DateTime?
  pixelId          String?
  audienceTier     String?
  placement      String?
  landingPageUrl String?
  adTitle        String?
  adDescription  String?
  adVideoUrl     String?
  adImageHash    String?
  metaPageId     String?
  metaIgActorId  String?
  metaAdCreativeId String?
  adCreatives    AdCreative[]
  metrics        CampaignMetric[]
  createdAt      DateTime       @default(now())
  launchedAt     DateTime?
  automationPhase   String?
  automationWarning String?
  adsDisabledCount  Int        @default(0)
  advertiserName    String?
  payerName         String?
}

model AdCreative {
  id           String         @id @default(cuid())
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  campaignId   String?
  campaign     Campaign?      @relation(fields: [campaignId], references: [id])
  name         String?
  audioUrl     String?
  videoClipUrl String?
  videoUrl     String?
  lyricsJson   Json?
  status       CreativeStatus @default(PENDING)
  createdAt    DateTime       @default(now())
}

model CampaignMetric {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id])
  date           DateTime
  spend          Float
  impressions    Int
  clicks         Int
  // Spotify side
  streamsBefore  Int?
  streamsAfter   Int?
  costPerStream  Float?   // computed: spend / (streamsAfter - streamsBefore)
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum CreativeStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model EarlyAccess {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("email") // "email" | "google"
  googleId  String?
  activated Boolean  @default(false)
  createdAt DateTime @default(now())
}